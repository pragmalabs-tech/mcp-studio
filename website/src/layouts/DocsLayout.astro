---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  current?: string;
}

const { title, current } = Astro.props;

const nav = [
  {
    group: "Getting started",
    items: [
      { label: "Overview", href: "/docs" },
      { label: "Your first test", href: "/docs/first-test" },
    ],
  },
  {
    group: "Manual testing",
    items: [
      { label: "Tool calls", href: "/docs/manual-testing#tools" },
      { label: "Resources", href: "/docs/manual-testing#resources" },
      { label: "Widget resource", href: "/docs/manual-testing#widget" },
    ],
  },
  {
    group: "Automation E2E Testing",
    items: [
      { label: "Record a session", href: "/docs/automation#record" },
      { label: "Replay & run", href: "/docs/automation#replay" },
    ],
  },
  {
    group: "Testing with real AI",
    items: [{ label: "ChatGPT, Claude, Copilot", href: "/docs/publishing" }],
  },
];

const pathname = Astro.url.pathname;

// Flat ordered list of unique pages for prev/next
const pages = [
  { label: "Overview", href: "/docs" },
  { label: "Your first test", href: "/docs/first-test" },
  { label: "Manual testing", href: "/docs/manual-testing" },
  { label: "Automation E2E Testing", href: "/docs/automation" },
  { label: "Testing with real AI", href: "/docs/publishing" },
];

const currentIndex = pages.findIndex((p) => p.href === pathname);
const prev = currentIndex > 0 ? pages[currentIndex - 1] : null;
const next = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;
---

<Base title={title}>
  <Nav />

  <div class="max-w-5xl mx-auto px-4 flex gap-12 min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden md:block w-44 shrink-0 pt-12">
      <nav class="sticky top-20 flex flex-col gap-6">
        {
          nav.map((section) => {
            const sectionActive = section.items.some(
              (item) => pathname === item.href.split("#")[0],
            );
            return (
              <div>
                <p
                  class={`text-[10px] uppercase tracking-widest mb-2 transition-colors ${sectionActive ? "text-[var(--foreground)]" : "text-[var(--muted-foreground)]"}`}
                >
                  {section.group}
                </p>
                <ul class="flex flex-col gap-0.5">
                  {section.items.map((item) => {
                    const itemActive = pathname === item.href.split("#")[0];
                    return (
                      <li>
                        <a
                          href={item.href}
                          class={`block text-xs py-0.5 transition-colors ${itemActive ? "text-[var(--foreground)]" : "text-[var(--muted-foreground)] hover:text-[var(--foreground)]"}`}
                        >
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          })
        }
      </nav>
    </aside>

    <!-- Content -->
    <main class="flex-1 pt-12 pb-24 min-w-0">
      <slot />

      {
        (prev || next) && (
          <div class="mt-16 pt-6 border-t border-[var(--border)] flex items-center justify-between gap-4">
            {prev ? (
              <a href={prev.href} class="flex flex-col gap-1 group">
                <span class="text-[10px] uppercase tracking-widest text-[var(--muted-foreground)]">
                  Previous
                </span>
                <span class="text-xs text-[var(--muted-foreground)] group-hover:text-[var(--foreground)] transition-colors">
                  &larr; {prev.label}
                </span>
              </a>
            ) : (
              <span />
            )}
            {next ? (
              <a href={next.href} class="flex flex-col gap-1 items-end group">
                <span class="text-[10px] uppercase tracking-widest text-[var(--muted-foreground)]">
                  Next
                </span>
                <span class="text-xs text-[var(--muted-foreground)] group-hover:text-[var(--foreground)] transition-colors">
                  {next.label} &rarr;
                </span>
              </a>
            ) : (
              <span />
            )}
          </div>
        )
      }
    </main>
  </div>

  <Footer />
</Base>

---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  current?: string;
}

const { title, current } = Astro.props;

const nav = [
  {
    group: "Getting started",
    items: [
      { label: "Overview", href: "/docs" },
      { label: "Make First Test", href: "/docs/first-test" },
    ],
  },
  {
    group: "Features",
    items: [
      { label: "Interface", href: "/docs/interface" },
      { label: "Connect MCP App", href: "/docs/connect-mcp-app" },
    ],
  },
];

const pathname = Astro.url.pathname;

const pages = [
  { label: "Overview", href: "/docs" },
  { label: "Your first test", href: "/docs/first-test" },
  { label: "Interface", href: "/docs/interface" },
  { label: "Connect MCP App", href: "/docs/connect-mcp-app" },
];

const currentIndex = pages.findIndex((p) => p.href === pathname);
const prev = currentIndex > 0 ? pages[currentIndex - 1] : null;
const next = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;
const currentPage = pages[currentIndex];
---

<Base title={title}>
  <Nav />

  <div class="max-w-6xl mx-auto px-4 flex gap-12 min-h-screen">
    <!-- Left sidebar (desktop only) -->
    <aside class="hidden md:block w-44 shrink-0 pt-12">
      <nav class="sticky top-20 flex flex-col gap-6">
        {
          nav.map((section) => {
            const sectionActive = section.items.some(
              (item) => pathname === item.href.split("#")[0],
            );
            return (
              <div>
                <p
                  class={`text-xs uppercase tracking-widest mb-2 transition-colors ${sectionActive ? "text-[var(--foreground)]" : "text-[var(--muted-foreground)]"}`}
                >
                  {section.group}
                </p>
                <ul class="flex flex-col gap-0.5">
                  {section.items.map((item) => {
                    const itemActive = pathname === item.href.split("#")[0];
                    return (
                      <li>
                        <a
                          href={item.href}
                          class={`block text-sm py-0.5 transition-colors ${itemActive ? "text-[var(--foreground)]" : "text-[var(--muted-foreground)] hover:text-[var(--foreground)]"}`}
                        >
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          })
        }
      </nav>
    </aside>

    <!-- Content -->
    <main class="flex-1 pt-12 pb-24 min-w-0">
      <!-- Mobile top bar with hamburger -->
      <div
        class="md:hidden flex items-center justify-between mb-8 px-3 py-2 border border-[var(--border)]"
      >
        <span class="text-xs text-[var(--muted-foreground)]">
          {currentPage ? currentPage.label : "Docs"}
        </span>
        <button
          id="docs-menu-btn"
          class="flex flex-col gap-1 p-1 text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
          aria-label="Open docs menu"
        >
          <span class="block w-4 h-px bg-current"></span>
          <span class="block w-4 h-px bg-current"></span>
          <span class="block w-4 h-px bg-current"></span>
        </button>
      </div>

      <slot />

      {
        (prev || next) && (
          <div class="mt-16 pt-6 border-t border-[var(--border)] flex items-center justify-between gap-4">
            {prev ? (
              <a href={prev.href} class="flex flex-col gap-1 group">
                <span class="text-xs uppercase tracking-widest text-[var(--muted-foreground)]">
                  Previous
                </span>
                <span class="text-sm text-[var(--muted-foreground)] group-hover:text-[var(--foreground)] transition-colors">
                  &larr; {prev.label}
                </span>
              </a>
            ) : (
              <span />
            )}
            {next ? (
              <a href={next.href} class="flex flex-col gap-1 items-end group">
                <span class="text-xs uppercase tracking-widest text-[var(--muted-foreground)]">
                  Next
                </span>
                <span class="text-sm text-[var(--muted-foreground)] group-hover:text-[var(--foreground)] transition-colors">
                  {next.label} &rarr;
                </span>
              </a>
            ) : (
              <span />
            )}
          </div>
        )
      }
    </main>

    <!-- Right TOC -->
    <aside class="hidden lg:block w-48 shrink-0 pt-12">
      <div class="sticky top-20">
        <p
          class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-3"
        >
          On this page
        </p>
        <nav id="toc" class="flex flex-col gap-0.5">
          <!-- populated by script -->
        </nav>
      </div>
    </aside>
  </div>

  <!-- Mobile drawer overlay -->
  <div
    id="docs-drawer-overlay"
    class="hidden fixed inset-0 z-40 bg-black/60 md:hidden"
  >
  </div>

  <!-- Mobile drawer panel -->
  <nav
    id="docs-drawer"
    class="fixed top-0 left-0 h-full w-64 z-50 bg-[var(--background)] border-r border-[var(--border)] overflow-y-auto transition-transform duration-200 ease-in-out md:hidden"
    style="transform: translateX(-100%)"
  >
    <div
      class="flex items-center justify-between px-4 py-3 border-b border-[var(--border)]"
    >
      <span
        class="text-xs uppercase tracking-widest text-[var(--muted-foreground)]"
        >Docs</span
      >
      <button
        id="docs-drawer-close"
        class="w-7 h-7 flex items-center justify-center text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
        aria-label="Close docs menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="px-4 py-4 flex flex-col gap-6">
      {
        nav.map((section) => {
          const sectionActive = section.items.some(
            (item) => pathname === item.href.split("#")[0],
          );
          return (
            <div>
              <p
                class={`text-xs uppercase tracking-widest mb-3 ${sectionActive ? "text-[var(--foreground)]" : "text-[var(--muted-foreground)]"}`}
              >
                {section.group}
              </p>
              <ul class="flex flex-col gap-1">
                {section.items.map((item) => {
                  const itemActive = pathname === item.href.split("#")[0];
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`drawer-nav-link block text-sm py-1.5 px-2 transition-colors ${itemActive ? "text-[var(--foreground)] bg-[var(--card)] border border-[var(--border)]" : "text-[var(--muted-foreground)] hover:text-[var(--foreground)]"}`}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })
      }
    </div>
  </nav>

  <Footer />
</Base>

<style is:global>
  main h2 {
    scroll-margin-top: 5rem; /* nav height (48px) + breathing room */
  }
</style>

<script>
  function buildToc() {
    const headings = Array.from(
      document.querySelectorAll<HTMLHeadingElement>("main h2"),
    );
    const toc = document.getElementById("toc");
    if (!toc || headings.length === 0) return;

    toc.innerHTML = headings
      .map(
        (h) =>
          `<a href="#${h.id}" class="block text-sm py-0.5 text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors toc-link" data-id="${h.id}">${h.textContent}</a>`,
      )
      .join("");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const link = toc.querySelector(`[data-id="${entry.target.id}"]`);
          if (link) {
            link.classList.toggle(
              "text-[var(--foreground)]",
              entry.isIntersecting,
            );
            link.classList.toggle(
              "text-[var(--muted-foreground)]",
              !entry.isIntersecting,
            );
          }
        });
      },
      { rootMargin: "0px 0px -80% 0px" },
    );

    headings.forEach((h) => observer.observe(h));
  }

  buildToc();
  document.addEventListener("astro:page-load", buildToc);

  function initCopy() {
    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy!;
        await navigator.clipboard.writeText(text);
        const original = btn.innerHTML;
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        btn.style.color = "rgb(16 185 129)";
        setTimeout(() => {
          btn.innerHTML = original;
          btn.style.color = "";
        }, 1500);
      });
    });
  }

  initCopy();
  document.addEventListener("astro:page-load", initCopy);

  function initDrawer() {
    const menuBtn = document.getElementById("docs-menu-btn");
    const closeBtn = document.getElementById("docs-drawer-close");
    const overlay = document.getElementById("docs-drawer-overlay");
    const drawer = document.getElementById("docs-drawer");
    if (!menuBtn || !closeBtn || !overlay || !drawer) return;

    function openDrawer() {
      overlay.classList.remove("hidden");
      drawer.style.transform = "translateX(0)";
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      overlay.classList.add("hidden");
      drawer.style.transform = "translateX(-100%)";
      document.body.style.overflow = "";
    }

    menuBtn.addEventListener("click", openDrawer);
    closeBtn.addEventListener("click", closeDrawer);
    overlay.addEventListener("click", closeDrawer);

    drawer.querySelectorAll(".drawer-nav-link").forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });
  }

  initDrawer();
  document.addEventListener("astro:page-load", initDrawer);
</script>

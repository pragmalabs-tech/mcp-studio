---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "MCP Studio — The interactive test studio for MCP apps",
  description = "MCP Studio runs locally and opens in your browser. Test widget interfaces, inspect tool flows interactively, and automate end-to-end tests for your MCP applications.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/pragmalabs.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const isDark = stored ? stored === "dark" : prefersDark !== false;
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

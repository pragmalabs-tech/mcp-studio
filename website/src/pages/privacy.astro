---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Privacy Policy — MCP Studio">
  <Nav />

  <main class="max-w-2xl mx-auto px-4 pt-16 pb-24">

    <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4">
      [ Legal ]
    </p>
    <h1 class="text-2xl font-bold text-[var(--foreground)] mb-2">Privacy Policy</h1>
    <p class="text-xs text-[var(--muted-foreground)] mb-12">Last updated: June 2025</p>

    <div class="flex flex-col gap-10 text-xs text-[var(--muted-foreground)] leading-relaxed">

      <section>
        <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">MCP Studio runs locally</h2>
        <p>
          MCP Studio is a local application. It runs on your machine and opens in your browser at
          <span class="text-[var(--foreground)]">localhost:7777</span>. Your MCP server, test data,
          recorded sessions, and replay results are stored on your filesystem under
          <span class="text-[var(--foreground)]">~/.mcp-studio/</span> and never leave your machine.
        </p>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">What we do not collect</h2>
        <ul class="flex flex-col gap-2">
          {[
            "Your MCP server URLs or credentials",
            "Tool inputs or outputs",
            "Recorded tests or replay results",
            "Widget content or mock data",
            "Usage analytics or telemetry",
          ].map((item) => (
            <li class="flex gap-2">
              <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]"></span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">Cloud account (optional)</h2>
        <p class="mb-3">
          The Publish feature requires a Pragma Labs account. When you sign in, we store your email
          address to identify your account and allocate tunnel subdomains. We do not share this
          information with third parties.
        </p>
        <p>
          Tunnel traffic passes through our relay servers only to route requests from the public URL
          to your local machine. We do not log or store the content of that traffic.
        </p>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">Cookies and tracking</h2>
        <p>
          This website does not use cookies or any third-party tracking scripts.
        </p>
      </section>

      <section>
        <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">Contact</h2>
        <p>
          Questions about this policy: <a href="mailto:team@pragmalabs.tech" class="text-[var(--foreground)] hover:underline">team@pragmalabs.tech</a>
        </p>
      </section>

    </div>

  </main>

  <Footer />
</Base>

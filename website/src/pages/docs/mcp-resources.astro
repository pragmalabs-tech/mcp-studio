---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="MCP Resources — MCP Studio" current="mcp-resources">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Features ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    MCP Resources
  </h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10"
  >
    MCP resources can return any content — text, JSON, or data. But because
    MCP Studio is built for MCP applications with UI, it gives first-class
    support to <strong class="text-[var(--foreground)]">UI resources</strong>:
    resources that return an HTML widget. These render live in the Widget
    Preview panel and let you inject tool input and output to test how the UI
    behaves — without running a full tool call.
  </p>

  <!-- Resource types -->
  <section class="mb-10">
    <h2
      id="resource-types"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Resource types
    </h2>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]"
    >
      {
        [
          {
            label: "Data resource",
            points: [
              "Returns text, JSON, or markdown",
              "Shown as read-only content in the preview panel",
              "No injection or interaction",
            ],
          },
          {
            label: "UI resource",
            points: [
              "Returns an HTML widget",
              "Renders live and interactively in the preview panel",
              "Supports toolInput / toolOutput injection to test UI with real data",
            ],
          },
        ].map((col) => (
          <div class="bg-[var(--card)] p-4">
            <p class="text-xs font-semibold text-[var(--foreground)] mb-3">
              {col.label}
            </p>
            <ul class="flex flex-col gap-1.5">
              {col.points.map((p) => (
                <li class="flex gap-2 text-sm text-[var(--muted-foreground)]">
                  <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]" />
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- UI resource callout -->
  <div class="border border-[var(--border)] bg-[var(--card)] p-4 mb-10">
    <p class="text-xs font-semibold text-[var(--foreground)] mb-2">
      Test your Widget UI before adding it to a tool
    </p>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
      UI resources are ideal for building and validating widget layout in
      isolation. Iterate on the HTML, use <strong
        class="text-[var(--foreground)]">Reload widget</strong
      > to instantly refresh the preview with the latest layout, and only wire
      the widget up to a tool once the UI looks right.
    </p>
  </div>

  <!-- How to read a resource -->
  <section class="mb-10">
    <h2
      id="how-to-read"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      How to read a resource
    </h2>
    <ol class="flex flex-col gap-6">
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >1</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Pick a resource
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Click any resource URI in the left sidebar under the active profile.
            The execution panel loads the Resource Request tab.
          </p>
        </div>
      </li>
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >2</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Execute
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Click <strong class="text-[var(--foreground)]">Execute</strong>.
            MCP Studio fetches the resource and renders the returned HTML in
            the Widget Preview panel. Use <strong
              class="text-[var(--foreground)]">Reload widget</strong
            > at any time to refresh the preview with the latest layout without
            re-fetching from the server.
          </p>
        </div>
      </li>
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >3</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Inject test data <span
              class="text-[10px] font-normal normal-case text-[var(--muted-foreground)]"
              >(optional, widget resources only)</span
            >
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            If the resource returns a widget, open the <strong
              class="text-[var(--foreground)]">Test Data</strong
            > tab and inject <code class="text-[var(--foreground)]"
              >toolInput</code
            > and <code class="text-[var(--foreground)]">toolOutput</code> to
            simulate how the UI renders with real data. Click <strong
              class="text-[var(--foreground)]">Inject</strong
            > to apply.
          </p>
        </div>
      </li>
    </ol>
    <AppWindow caption="Reading a resource and interacting with the rendered widget UI." class="mt-6">
      <img
        src="/screenshots/mcp-studio-resource-ui-read.gif"
        alt="Reading a resource and interacting with the widget in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Injecting test data -->
  <section class="mb-10">
    <h2
      id="injecting-test-data"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Injecting test data
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Widget resources are HTML templates — they expect tool input and output
      to be passed in so they can render meaningful content. The <strong
        class="text-[var(--foreground)]">Test Data</strong
      > tab lets you supply that data without wiring up a full tool call first.
    </p>
    <div class="border border-[var(--border)] bg-[var(--card)]">
      <div
        class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="ml-2 text-xs text-[var(--muted-foreground)]"
          >Test Data tab — inject shape</span
        >
        <button
          class="copy-btn ml-auto text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
          data-copy={`{
  "toolInput": {
    "elements": "[{\\"type\\":\\"cameraUpdate\\",\\"width\\":800,\\"height\\":600,\\"x\\":0,\\"y\\":0},{\\"type\\":\\"rectangle\\",\\"id\\":\\"b1\\",\\"x\\":100,\\"y\\":220,\\"width\\":180,\\"height\\":80,\\"roundness\\":{\\"type\\":3},\\"backgroundColor\\":\\"#a5d8ff\\",\\"fillStyle\\":\\"solid\\",\\"strokeColor\\":\\"#4a9eed\\",\\"strokeWidth\\":2,\\"label\\":{\\"text\\":\\"Hello\\",\\"fontSize\\":22}},{\\"type\\":\\"arrow\\",\\"id\\":\\"a1\\",\\"x\\":280,\\"y\\":260,\\"width\\":160,\\"height\\":0,\\"points\\":[[0,0],[160,0]],\\"endArrowhead\\":\\"arrow\\",\\"strokeColor\\":\\"#1e1e1e\\",\\"strokeWidth\\":2},{\\"type\\":\\"rectangle\\",\\"id\\":\\"b2\\",\\"x\\":440,\\"y\\":220,\\"width\\":220,\\"height\\":80,\\"roundness\\":{\\"type\\":3},\\"backgroundColor\\":\\"#d0bfff\\",\\"fillStyle\\":\\"solid\\",\\"strokeColor\\":\\"#8b5cf6\\",\\"strokeWidth\\":2,\\"label\\":{\\"text\\":\\"MCP Studio\\",\\"fontSize\\":22}}]"
  },
  "toolOutput": {}
}`}
          title="Copy"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="9" y="9" width="13" height="13" rx="2"></rect><path
              d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
        </button>
      </div>
      <pre
        class="px-4 py-3 text-xs text-[var(--foreground)] leading-relaxed overflow-x-auto"
        ><code>{`{
  "toolInput": {
    "elements": "[
      { \\"type\\": \\"cameraUpdate\\", \\"width\\": 800, \\"height\\": 600 },
      { \\"type\\": \\"rectangle\\", \\"id\\": \\"b1\\", \\"label\\": { \\"text\\": \\"Hello\\" }, ... },
      { \\"type\\": \\"arrow\\",     \\"id\\": \\"a1\\", ... },
      { \\"type\\": \\"rectangle\\", \\"id\\": \\"b2\\", \\"label\\": { \\"text\\": \\"MCP Studio\\" }, ... }
    ]"
  },
  "toolOutput": {}
}`}</code></pre
      >
    </div>
    <p class="text-sm text-[var(--muted-foreground)] mt-3">
      <code class="text-[var(--foreground)]">toolInput</code> mirrors the arguments
      you would pass to the corresponding tool. <code
        class="text-[var(--foreground)]">toolOutput</code
      > holds any additional data the tool would have returned. Together they let
      the widget render as if a real tool call had just completed.
    </p>
  </section>

  <!-- Resources vs Tools -->
  <section class="mb-10">
    <h2
      id="resources-vs-tools"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Resources vs Tools
    </h2>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]"
    >
      {
        [
          {
            label: "MCP Tools",
            points: [
              "Execute server-side logic with arguments",
              "Return data or a rendered widget",
              "Recorded as test steps",
            ],
          },
          {
            label: "MCP Resources",
            points: [
              "Fetch content from the server (data or UI widget)",
              "UI resources render live and support toolInput / toolOutput injection",
              "Ideal for developing and validating widget layout before adding a tool",
            ],
          },
        ].map((col) => (
          <div class="bg-[var(--card)] p-4">
            <p class="text-xs font-semibold text-[var(--foreground)] mb-3">
              {col.label}
            </p>
            <ul class="flex flex-col gap-1.5">
              {col.points.map((p) => (
                <li class="flex gap-2 text-sm text-[var(--muted-foreground)]">
                  <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]" />
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</DocsLayout>

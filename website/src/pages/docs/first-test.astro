---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="Your first test — MCP Studio" current="first-test">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Getting started ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    Your first test
  </h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-8"
  >
    Test your MCP application manually, then turn your session into an automated
    end-to-end test in under 5 minutes.
  </p>

  <div class="mb-12 border border-[var(--border)] overflow-hidden aspect-video">
    <iframe
      src="https://www.youtube.com/embed/vCbNQKFpN78?vq=hd2160"
      title="MCP Studio demo"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      class="w-full h-full"></iframe>
  </div>

  <ol class="flex flex-col gap-8">
    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >1</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="start-mcp-studio"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Start MCP Studio
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
          Run `mcp-studio` in your terminal — it will open localhost:7777 in
          your browser automatically, or you can navigate there manually.
        </p>
        <div class="border border-[var(--border)] bg-[var(--card)]">
          <pre class="px-4 py-3 text-xs text-[var(--foreground)]"
            ><code><span class="text-emerald-400">$</span> mcp-studio</code></pre
          >
        </div>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >2</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="create-profile"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Connect your MCP application
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          You need to prepare your mcp server url to connect your MCP
          application. For authentication, MCP Studio supports OAuth2.1,
          header-based authentication.
        </p>
        <br />
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          By default, MCP Studio includes an Excalidraw profile at
          https://mcp.excalidraw.com/mcp
        </p>
        <AppWindow
          caption="Profile editor: enter your MCP application URL and a name to save it."
          class="mt-4"
        >
          <img
            src="/screenshots/mcp-studio-setup-profile.gif"
            alt="Setting up a profile in MCP Studio"
            class="w-full block"
            data-lightbox
          />
        </AppWindow>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >3</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="call-a-tool"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Call a tool
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
          Pick a tool from the sidebar, fill in the arguments under the Tool
          Arguments tab, and click Execute. The response appears in the Logs
          panel below.
        </p>
        <p class="text-xs text-[var(--muted-foreground)] mb-2">
          In the example below we call <code class="text-[var(--foreground)]"
            >create_view</code
          > with:
        </p>
        <div class="border border-[var(--card)] bg-[var(--card)] mb-4">
          <div
            class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]"
          >
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="ml-2 text-xs text-[var(--muted-foreground)]"
              >create_view</span
            >
            <button
              class="copy-btn ml-auto text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
              data-copy={`{\n  "elements": "[{\\"type\\":\\"rectangle\\",\\"id\\":\\"b1\\",\\"x\\":100,\\"y\\":220,\\"width\\":180,\\"height\\":80,\\"roundness\\":{\\"type\\":3},\\"backgroundColor\\":\\"#a5d8ff\\",\\"fillStyle\\":\\"solid\\",\\"strokeColor\\":\\"#4a9eed\\",\\"strokeWidth\\":2,\\"label\\":{\\"text\\":\\"Hello\\",\\"fontSize\\":22}},{\\"type\\":\\"arrow\\",\\"id\\":\\"a1\\",\\"x\\":280,\\"y\\":260,\\"width\\":160,\\"height\\":0,\\"points\\":[[0,0],[160,0]],\\"endArrowhead\\":\\"arrow\\",\\"strokeColor\\":\\"#1e1e1e\\",\\"strokeWidth\\":2},{\\"type\\":\\"rectangle\\",\\"id\\":\\"b2\\",\\"x\\":440,\\"y\\":220,\\"width\\":220,\\"height\\":80,\\"roundness\\":{\\"type\\":3},\\"backgroundColor\\":\\"#d0bfff\\",\\"fillStyle\\":\\"solid\\",\\"strokeColor\\":\\"#8b5cf6\\",\\"strokeWidth\\":2,\\"label\\":{\\"text\\":\\"MCP Studio\\",\\"fontSize\\":22}}]"\n}`}
              title="Copy"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="9" y="9" width="13" height="13" rx="2"></rect><path
                  d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                ></path>
              </svg>
            </button>
          </div>
          <pre
            class="px-4 py-3 text-xs text-[var(--foreground)] leading-relaxed overflow-x-auto scrollbar-none"
            ><code>{`{
  "elements": "[
    { "type": "rectangle", "id": "b1", "label": { "text": "Hello" }, ... },
    { "type": "arrow",     "id": "a1", ... },
    { "type": "rectangle", "id": "b2", "label": { "text": "MCP Studio" }, ... }
  ]"
}`}</code></pre
          >
        </div>
        <AppWindow
          caption="Executing a tool and inspecting the response in the log."
          class="mt-2"
        >
          <img
            src="/screenshots/mcp-studio-execute-tool.gif"
            alt="Calling a tool in MCP Studio"
            class="w-full block"
            data-lightbox
          />
        </AppWindow>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >4</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="interact-with-widget"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Interact with widget UI
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
          If the tool returns a widget, it renders automatically in the Preview
          panel. Use the top bar to switch between ChatGPT, Claude, desktop, and
          mobile viewports and interact with it just as your users would.
        </p>
        <AppWindow
          caption="Widget rendered live — switching viewports in the preview panel."
          class="mt-2"
        >
          <img
            src="/screenshots/mcp-studio-interactive-with-widget.gif"
            alt="Interacting with a widget in MCP Studio"
            class="w-full block"
            data-lightbox
          />
        </AppWindow>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >5</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="record-session"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Record the session
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
          Click <strong class="text-[var(--foreground)]">Record Test</strong> in the
          toolbar, repeat the tool calls you want to capture, then click
          <strong class="text-[var(--foreground)]">Stop Record Test</strong>.
          Give the test a name and save it — no code to write.
        </p>
        <div class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <AppWindow caption="Click Record Test to start capturing.">
            <img
              src="/screenshots/mcp-studio-record-test.png"
              alt="Record Test button in MCP Studio"
              class="w-full block"
              data-lightbox
            />
          </AppWindow>
          <AppWindow caption="Click Stop Record Test, name it, and save.">
            <img
              src="/screenshots/mcp-studio-stop-record-test.png"
              alt="Stop Record Test dialog in MCP Studio"
              class="w-full block"
              data-lightbox
            />
          </AppWindow>
        </div>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >6</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="verify-e2e-test"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Run step-by-step
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
          Open the Tests panel, find the test you just saved, and use the
          step-by-step controls to replay it one action at a time. Each step
          shows its result inline so you can pinpoint exactly where something
          differs.
        </p>
        <AppWindow
          caption="Stepping through a recorded test one action at a time."
          class="mt-2"
        >
          <img
            src="/screenshots/mcp-studio-run-step-by-step-test.gif"
            alt="Step-by-step test replay in MCP Studio"
            class="w-full block"
            data-lightbox
          />
        </AppWindow>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
        >7</span
      >
      <div class="flex-1 min-w-0">
        <h2
          id="replay-e2e-test"
          class="text-sm font-semibold text-[var(--foreground)] mb-1"
        >
          Replay E2E test
        </h2>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
          Run the full test suite any time after a code change or new release.
          Every recorded step is replayed automatically and checked against the
          saved assertions — a pass/fail report is shown at the end.
        </p>
        <AppWindow
          caption="Full E2E replay with pass/fail results."
          class="mt-2"
        >
          <img
            src="/screenshots/mcp-studio-replay-test.gif"
            alt="E2E test replay results in MCP Studio"
            class="w-full block"
            data-lightbox
          />
        </AppWindow>
      </div>
    </li>
  </ol>
</DocsLayout>

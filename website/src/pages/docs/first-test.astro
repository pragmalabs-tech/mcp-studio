---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Your first test — MCP Studio" current="first-test">
  <p
    class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Getting started ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    Your first test
  </h1>
  <p
    class="text-sm text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-12"
  >
    [Intro: walk through connecting a server, calling a tool, and turning the
    session into a test.]
  </p>

  <ol class="flex flex-col gap-8">
    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]"
        >1</span
      >
      <div>
        <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
          Start MCP Studio
        </p>
        <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-3">
          [How to run mcp-studio and open the browser.]
        </p>
        <div class="border border-[var(--border)] bg-[var(--card)]">
          <pre
            class="px-4 py-3 text-xs text-[var(--foreground)]"><code><span class="text-emerald-400">$</span> mcp-studio</code></pre>
        </div>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]"
        >2</span
      >
      <div>
        <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
          Connect your MCP server
        </p>
        <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">
          [Where to enter the server URL. Mention profiles for saving multiple
          servers.]
        </p>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]"
        >3</span
      >
      <div>
        <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
          Call a tool
        </p>
        <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">
          [Pick a tool from the sidebar, fill in the arguments, and run it. Show
          where the result appears.]
        </p>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]"
        >4</span
      >
      <div>
        <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
          Record the session
        </p>
        <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">
          [Click Record, repeat the tool call, click Stop, name the test, save.]
        </p>
      </div>
    </li>

    <li class="flex gap-4">
      <span
        class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]"
        >5</span
      >
      <div>
        <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
          Replay and verify
        </p>
        <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">
          [Open the Tests drawer, find the test, run it. Walk through what a
          passing and failing result looks like.]
        </p>
      </div>
    </li>
  </ol>

  <div class="mt-12 flex gap-4">
    <a
      href="/docs/manual-testing"
      class="text-xs text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
    >
      Manual testing &rarr;
    </a>
    <a
      href="/docs/automation"
      class="text-xs text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
    >
      Automation E2E &rarr;
    </a>
  </div>
</DocsLayout>

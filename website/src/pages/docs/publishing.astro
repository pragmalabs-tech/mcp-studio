---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Publishing — MCP Studio" current="publishing">

  <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4">
    [ Testing with real AI ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">Testing with ChatGPT, Claude, and Copilot</h1>
  <p class="text-sm text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-12">
    [Intro: expose your local MCP server to a public HTTPS URL so you can connect it to real ChatGPT or Claude.]
  </p>

  <!-- How it works -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">How it works</h2>
    <ol class="flex flex-col gap-3">
      {[
        "Sign in with your Pragma Labs account in the Cloud panel.",
        "Click Publish in the top bar.",
        "Enter a subdomain or leave blank for a random one.",
        "Your server is now live at https://[subdomain].tunnel.mcpr.app.",
        "Paste that URL into ChatGPT or Claude as a custom MCP server.",
      ].map((step, i) => (
        <li class="flex gap-3 text-xs text-[var(--muted-foreground)]">
          <span class="shrink-0 w-5 h-5 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]">
            {i + 1}
          </span>
          {step}
        </li>
      ))}
    </ol>
  </section>

  <!-- Tunnel URL format -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">Tunnel URL</h2>
    <div class="border border-[var(--border)] bg-[var(--card)] px-4 py-3">
      <code class="text-xs text-emerald-400">https://[subdomain].tunnel.mcpr.app</code>
    </div>
    <p class="text-xs text-[var(--muted-foreground)] mt-3 leading-relaxed max-w-lg">
      [Any note about tunnel lifetime, auth, or subdomain reuse.]
    </p>
  </section>

  <!-- Connecting to ChatGPT / Claude -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">Connecting to ChatGPT, Claude, and Copilot</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]">
      {[
        { platform: "ChatGPT", desc: "[Where to paste the URL in ChatGPT settings.]" },
        { platform: "Claude", desc: "[Where to paste the URL in Claude settings.]" },
        { platform: "Copilot", desc: "[Where to paste the URL in GitHub Copilot settings.]" },
      ].map((item) => (
        <div class="bg-[var(--card)] p-4">
          <p class="text-xs font-semibold text-[var(--foreground)] mb-1">{item.platform}</p>
          <p class="text-xs text-[var(--muted-foreground)]">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <div class="border border-dashed border-[var(--border)] h-40 flex items-center justify-center text-xs text-[var(--muted-foreground)]">
    screenshot: publish dialog
  </div>

</DocsLayout>

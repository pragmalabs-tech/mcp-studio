---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="Docs — MCP Studio" current="overview">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Docs ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">Overview</h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10"
  >
    MCP Studio is a local testing tool for MCP applications. It lets you test
    widget UI, call tools, and automate end-to-end tests by replaying your
    interactive steps without writing code. Designed for both humans and agent
    tools (Claude Code, ChatGPT, Copilot, and others) via MCP.
  </p>

  <AppWindow
    caption="MCP Studio running with the Excalidraw MCP application"
    class="mb-10"
  >
    <img
      src="/screenshots/mcp-studio.png"
      alt="MCP Studio"
      class="w-full block"
      data-lightbox
    />
  </AppWindow>

  <!-- Install -->
  <section class="mb-10">
    <h2
      id="install"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Install
    </h2>
    <div class="flex flex-col gap-4">
      <!-- npx -->
      <div>
        <p class="text-xs text-[var(--muted-foreground)] mb-1">npx</p>
        <p class="text-xs text-[var(--muted-foreground)] mb-2 opacity-60">No install needed. Run once or try it out.</p>
        <div class="border border-[var(--border)] bg-[var(--card)]">
          <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="ml-2 text-xs text-[var(--muted-foreground)]">terminal</span>
          </div>
          <pre class="px-4 py-4 text-xs text-[var(--foreground)] leading-relaxed"
            ><code><span class="text-emerald-400">$</span> npx @pragmalabs/mcp-studio</code></pre>
        </div>
      </div>
      <!-- script -->
      <div>
        <p class="text-xs text-[var(--muted-foreground)] mb-1">script</p>
        <p class="text-xs text-[var(--muted-foreground)] mb-2 opacity-60">Installs the binary to ~/.local/bin. Best for Linux or if you don't use Homebrew.</p>
        <div class="border border-[var(--border)] bg-[var(--card)]">
          <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="ml-2 text-xs text-[var(--muted-foreground)]">terminal</span>
          </div>
          <pre class="px-4 py-4 text-xs text-[var(--foreground)] leading-relaxed"
            ><code><span class="text-emerald-400">$</span> curl -fsSL https://studio.pragmalabs.tech/install.sh | sh</code></pre>
        </div>
      </div>
      <!-- homebrew -->
      <div>
        <p class="text-xs text-[var(--muted-foreground)] mb-1">homebrew</p>
        <p class="text-xs text-[var(--muted-foreground)] mb-2 opacity-60">Recommended for macOS. Managed installs and easy upgrades with brew upgrade.</p>
        <div class="border border-[var(--border)] bg-[var(--card)]">
          <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="ml-2 text-xs text-[var(--muted-foreground)]">terminal</span>
          </div>
          <pre class="px-4 py-4 text-xs text-[var(--foreground)] leading-relaxed"
            ><code><span class="text-emerald-400">$</span> brew tap pragmalabs-tech/mcp-studio
<span class="text-emerald-400">$</span> brew install mcp-studio</code></pre>
        </div>
      </div>
    </div>
    <p class="text-sm text-[var(--muted-foreground)] mt-3">
      Opens at <span class="text-[var(--foreground)]">localhost:7777</span>
    </p>
  </section>

  <!-- Supported Platform and MCP Methods -->
  <section class="mb-10">
    <h2
      id="supported-platforms"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Supported Platform and MCP Methods
    </h2>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]"
    >
      <div class="bg-[var(--card)] p-4">
        <p
          class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-3"
        >
          Platform
        </p>
        <ul class="flex flex-col gap-1.5">
          {
            ["macOS", "Linux"].map((item) => (
              <li class="flex gap-2 text-sm text-[var(--muted-foreground)]">
                <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="bg-[var(--card)] p-4">
        <p
          class="text-xs uppercase tracking-widest text-[var(--muted-foreground)] mb-3"
        >
          MCP methods
        </p>
        <ul class="flex flex-col gap-1.5">
          {
            [
              "Tools",
              "Resources",
              "OAuth 2.1 + PKCE",
              "Bearer token",
              "Custom headers",
            ].map((item) => (
              <li class="flex gap-2 text-sm text-[var(--muted-foreground)]">
                <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- What you can do -->
  <section class="mb-10">
    <h2
      id="what-you-can-do"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      What you can do
    </h2>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]"
    >
      {
        [
          {
            label: "Connect an MCP App",
            desc: "Add a profile with your MCP server URL and authentication credentials.",
            href: "/docs/connect-mcp-app",
          },
          {
            label: "Manual testing",
            desc: "Call tools, read resources, and interact with widgets live in your browser.",
            href: "/docs/manual-testing",
          },
          {
            label: "Automation E2E Testing",
            desc: "Record a session and turn it into a repeatable test.",
            href: "/docs/automation",
          },
          {
            label: "Testing with real AI",
            desc: "Expose your local server to a public URL and connect it to ChatGPT, Claude, or Copilot.",
            href: "/docs/publishing",
          },
        ].map((item) => (
          <a
            href={item.href}
            class="block border-[var(--border)] bg-[var(--card)] p-4 hover:bg-[var(--secondary)] transition-colors"
          >
            <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
              {item.label}
            </p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              {item.desc}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Legal -->
  <section class="mb-10">
    <h2
      id="legal"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Legal
    </h2>
    <div class="flex flex-col gap-px border border-[var(--border)]">
      {
        [
          {
            label: "Privacy Policy",
            desc: "MCP Studio runs locally. We do not collect your data.",
            href: "/privacy",
          },
          {
            label: "Terms of Service",
            desc: "Usage terms for MCP Studio.",
            href: "/terms",
          },
          { label: "Contact", desc: "team@pragmalabs.tech", href: "/contact" },
        ].map((item) => (
          <a
            href={item.href}
            class="flex items-center justify-between px-4 py-3 bg-[var(--card)] hover:bg-[var(--secondary)] transition-colors"
          >
            <div>
              <p class="text-sm font-semibold text-[var(--foreground)]">
                {item.label}
              </p>
              <p class="text-sm text-[var(--muted-foreground)]">{item.desc}</p>
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="11"
              height="11"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0 text-[var(--muted-foreground)]"
            >
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </a>
        ))
      }
    </div>
  </section>
</DocsLayout>

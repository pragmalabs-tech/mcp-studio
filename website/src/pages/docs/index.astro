---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Docs — MCP Studio" current="overview">

  <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4">
    [ Docs ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">Overview</h1>
  <p class="text-sm text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10">
    [One or two sentences: what MCP Studio does, who it's for.]
  </p>

  <!-- Install -->
  <section class="mb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3">Install</h2>
    <div class="border border-[var(--border)] bg-[var(--card)]">
      <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
        <span class="ml-2 text-[10px] text-[var(--muted-foreground)]">terminal</span>
      </div>
      <pre class="px-4 py-4 text-xs text-[var(--foreground)] leading-relaxed"><code><span class="text-[var(--muted-foreground)]"># Install</span>
<span class="text-emerald-400">$</span> curl -fsSL https://dl.pragmalabs.tech/mcp-studio/install.sh | sh

<span class="text-[var(--muted-foreground)]"># Run</span>
<span class="text-emerald-400">$</span> mcp-studio</code></pre>
    </div>
    <p class="text-xs text-[var(--muted-foreground)] mt-3">
      Opens at <span class="text-[var(--foreground)]">localhost:7777</span>. macOS and Linux supported.
    </p>
  </section>

  <!-- What you can do -->
  <section class="mb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4">What you can do</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]">
      {[
        { label: "Manual testing", desc: "Call tools, read resources, and interact with widgets live in your browser.", href: "/docs/manual-testing" },
        { label: "Automation E2E Testing", desc: "Record a session and turn it into a repeatable test.", href: "/docs/automation" },
        { label: "Testing with real AI", desc: "Expose your local server to a public URL and connect it to ChatGPT, Claude, or Copilot.", href: "/docs/publishing" },
      ].map((item) => (
        <a href={item.href} class="block border-[var(--border)] bg-[var(--card)] p-4 hover:bg-[var(--secondary)] transition-colors">
          <p class="text-xs font-semibold text-[var(--foreground)] mb-1">{item.label}</p>
          <p class="text-xs text-[var(--muted-foreground)] leading-relaxed">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>

</DocsLayout>

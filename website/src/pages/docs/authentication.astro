---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="MCP Authentication — MCP Studio" current="authentication">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Features ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    MCP Authentication
  </h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10"
  >
    MCP Studio supports OAuth 2.1 + PKCE, Bearer token, and custom headers. Each
    profile stores its own credentials, so switching profiles also switches
    auth. For OAuth, a built-in debugger lets you trace every step of the flow
    and inspect the issued token.
  </p>

  <!-- Auth methods -->
  <section class="mb-10">
    <h2
      id="auth-methods"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-4"
    >
      Auth methods
    </h2>
    <div class="flex flex-col gap-px border border-[var(--border)]">
      <div class="bg-[var(--card)] p-4">
        <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
          OAuth 2.1 + PKCE
        </p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          Full Authorization Code + PKCE flow. MCP Studio handles discovery,
          dynamic client registration, user authorization, and token exchange
          automatically. Tokens are stored per origin and refreshed when they
          expire.
        </p>
      </div>
      <div class="bg-[var(--card)] p-4">
        <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
          Bearer token
        </p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          A static token sent as <code class="text-[var(--foreground)]"
            >Authorization: Bearer &lt;token&gt;</code
          > on every request. Paste it in the profile's Bearer field.
        </p>
      </div>
      <div class="bg-[var(--card)] p-4">
        <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
          Custom headers
        </p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          A JSON object of arbitrary HTTP headers attached to every request.
          Useful for API keys, tenant IDs, or multi-header schemes.
        </p>
      </div>
      <div class="bg-[var(--card)] p-4">
        <p class="text-sm font-semibold text-[var(--foreground)] mb-1">None</p>
        <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
          Requests go out unauthenticated. Use this for local servers that do
          not require auth.
        </p>
      </div>
    </div>
  </section>

  <!-- Connect with OAuth 2.1 -->
  <section class="mb-10">
    <h2
      id="connect-oauth"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Connect with OAuth 2.1
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Select <strong class="text-[var(--foreground)]">OAuth</strong> as the auth method
      for a profile, then open the Authentication panel in the sidebar and click <strong
        class="text-[var(--foreground)]">Sign In with OAuth</strong
      >. MCP Studio runs the full flow in the background — discovery,
      registration, user authorization, and token exchange — and turns the
      status dot green when connected.
    </p>
    <ol class="flex flex-col gap-4 mb-6">
      {
        [
          "MCP Studio discovers the server's OAuth metadata from /.well-known/oauth-authorization-server.",
          "It registers a client dynamically via RFC 7591 if the server supports it.",
          "A browser popup opens for the user authorization step.",
          "After approval, MCP Studio exchanges the authorization code + PKCE verifier for a token.",
          "The token is stored in browser storage keyed by origin and used on every subsequent request.",
        ].map((step, i) => (
          <li class="flex gap-4">
            <span class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]">
              {i + 1}
            </span>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed pt-0.5">
              {step}
            </p>
          </li>
        ))
      }
    </ol>
    <AppWindow caption="Connecting to an MCP app that requires OAuth 2.1.">
      <img
        src="/screenshots/mcp-studio-auth.gif"
        alt="OAuth 2.1 connection flow in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- OAuth Debugger -->
  <section class="mb-10">
    <h2
      id="oauth-debugger"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      OAuth debugger
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-6">
      When OAuth is active the debugger panel appears alongside the
      authentication panel. It has three tabs that give you full visibility into
      the flow — useful for diagnosing connection failures or verifying your
      server's OAuth implementation.
    </p>

    <!-- Timeline -->
    <div class="mb-6">
      <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
        Timeline
      </p>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
        A live log of every OAuth step — Discovery, Registration, Authorize,
        Token, Refresh — with status indicators and the full request and
        response for each. Click any entry to expand the HTTP details. A flow
        visualization at the top shows which steps passed, are pending, or
        failed at a glance.
      </p>
      <AppWindow
        caption="Timeline tab — step-by-step OAuth flow with request and response details."
      >
        <img
          src="/screenshots/mcp-studio-auth-flow.png"
          alt="OAuth debugger timeline tab"
          class="w-full block"
          data-lightbox
        />
      </AppWindow>
    </div>

    <!-- Compliance -->
    <div class="mb-6">
      <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
        Compliance
      </p>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
        Validates the server's OAuth metadata against the MCP specification.
        Each field is checked and marked pass, warn, or fail. PKCE parameters (<code
          class="text-[var(--foreground)]">code_verifier</code
        > and <code class="text-[var(--foreground)]">state</code>) are also
        shown here while a flow is in progress.
      </p>
      <AppWindow
        caption="Compliance tab — MCP spec checks and PKCE parameters."
      >
        <img
          src="/screenshots/mcp-studio-auth-compliance.png"
          alt="OAuth debugger compliance tab"
          class="w-full block"
          data-lightbox
        />
      </AppWindow>
    </div>

    <!-- Token -->
    <div>
      <p class="text-sm font-semibold text-[var(--foreground)] mb-1">Token</p>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
        Decodes and displays the issued token. For JWT tokens the header and
        payload are shown in full, along with granted scopes and expiry time.
        Opaque tokens are shown as raw. You can copy the raw token directly from
        this tab.
      </p>
      <AppWindow
        caption="Token tab — decoded JWT with header, payload, scopes, and expiry."
      >
        <img
          src="/screenshots/mcp-studio-auth-token-contains.png"
          alt="OAuth debugger token tab"
          class="w-full block"
          data-lightbox
        />
      </AppWindow>
    </div>
  </section>
</DocsLayout>

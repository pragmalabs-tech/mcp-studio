---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="Connect MCP App — MCP Studio" current="connect-mcp-app">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Interface ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    Connect an MCP App
  </h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10"
  >
    A <strong class="text-[var(--foreground)]">Profile</strong> stores an MCP server
    URL and its credentials. Every tool call, resource read, and test replay is
    routed through the active profile — switching profiles re-routes everything
    instantly without touching your tests.
  </p>

  <!-- What is a Profile -->
  <section class="mb-10">
    <h2
      id="what-is-a-profile"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      What is a Profile
    </h2>
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)]"
    >
      {
        [
          {
            label: "Name",
            desc: "A human-readable label shown in the sidebar and test run reports.",
          },
          {
            label: "Server URL",
            desc: "The MCP endpoint to connect to, e.g. http://localhost:9000 or https://mcp.example.com/mcp.",
          },
        ].map((item) => (
          <div class="bg-[var(--card)] p-4">
            <p class="text-xs font-semibold text-[var(--foreground)] mb-1">
              {item.label}
            </p>
            <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
              {item.desc}
            </p>
          </div>
        ))
      }
    </div>
    <p class="text-sm text-[var(--muted-foreground)] mt-3">
      MCP Studio ships with a default Excalidraw profile so you can explore the
      UI immediately. Replace it or add more profiles for your own servers.
    </p>
  </section>

  <!-- Open the Profile Manager -->
  <section class="mb-10">
    <h2
      id="open-profile-manager"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Open the Profile Manager
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Click the <strong class="text-[var(--foreground)]">Profile</strong> section
      in the left sidebar to expand it, then click the profile name or the pencil
      icon. The Profiles dialog opens with the active profile already in edit mode.
    </p>
    <AppWindow caption="Profile panel in the sidebar — click to open the profile manager.">
      <img
        src="/screenshots/mcp-studio-setup-profile.gif"
        alt="Opening the profile manager in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Create or Edit a Profile -->
  <section class="mb-10">
    <h2
      id="create-or-edit"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Create or Edit a Profile
    </h2>
    <ol class="flex flex-col gap-6">
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >1</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Enter a name
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Give the profile a descriptive label — e.g. <code
              class="text-[var(--foreground)]">Local dev</code
            > or <code class="text-[var(--foreground)]">Staging</code>.
          </p>
        </div>
      </li>
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >2</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Set the server URL
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
            Paste the full URL to your MCP endpoint. Local servers and remote
            HTTPS endpoints are both supported.
          </p>
          <div class="border border-[var(--border)] bg-[var(--card)]">
            <div
              class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]"
            >
              <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
              <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
              <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
              <span class="ml-2 text-xs text-[var(--muted-foreground)]"
                >examples</span
              >
            </div>
            <pre
              class="px-4 py-3 text-xs text-[var(--foreground)] leading-relaxed"
              ><code>http://localhost:9000
http://localhost:9000/mcp
https://mcp.example.com/mcp</code></pre
            >
          </div>
        </div>
      </li>
      <li class="flex gap-4">
        <span
          class="shrink-0 w-6 h-6 border border-[var(--border)] flex items-center justify-center text-xs text-[var(--foreground)]"
          >3</span
        >
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">
            Save and activate
          </p>
          <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
            Click <strong class="text-[var(--foreground)]">Save</strong> to persist
            the profile, then click the profile row to activate it. The green dot
            in the sidebar confirms the connection is live.
          </p>
        </div>
      </li>
    </ol>
    <AppWindow caption="Profile editor — name and URL fields." class="mt-6">
      <img
        src="/screenshots/edit-profile.png"
        alt="Profile editor dialog in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Switch Profiles -->
  <section class="mb-10">
    <h2
      id="switch-profiles"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Switch Profiles
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Open the Profiles dialog from the sidebar and click any profile row to
      activate it. The active profile shows a green check badge. All subsequent
      tool calls and test replays immediately use that profile's URL.
    </p>
    <AppWindow caption="Switching the active profile from the sidebar." class="mb-4">
      <img
        src="/screenshots/mcp-studio-switch-profile.gif"
        alt="Switching profiles in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
    <div class="border border-[var(--border)] bg-[var(--card)] p-4">
      <p class="text-xs font-semibold text-[var(--foreground)] mb-2">
        Tip — per-environment profiles
      </p>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
        Keep separate profiles for <code class="text-[var(--foreground)]"
          >Local dev</code
        >, <code class="text-[var(--foreground)]">Staging</code>, and <code
          class="text-[var(--foreground)]">Production</code
        >. Switching profiles re-routes every test without any edits — useful
        for a quick smoke-test after a deploy.
      </p>
    </div>
  </section>

  <!-- Profiles and Tests -->
  <section class="mb-10">
    <h2
      id="profiles-and-tests"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Profiles and Tests
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-3">
      Tests are not bound to a profile at record time — they replay against
      whichever profile is currently active. This means:
    </p>
    <ul class="flex flex-col gap-2">
      {
        [
          "Record once against your local dev server, then replay the same test on staging by switching profiles.",
          "Update a profile's URL and every test picks up the change automatically.",
          "You cannot delete the last profile — at least one must exist to keep tests runnable.",
        ].map((item) => (
          <li class="flex gap-2 text-sm text-[var(--muted-foreground)]">
            <span class="mt-1.5 shrink-0 w-1 h-1 bg-[var(--muted-foreground)]" />
            {item}
          </li>
        ))
      }
    </ul>
  </section>
</DocsLayout>

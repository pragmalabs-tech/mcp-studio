---
import DocsLayout from "../../layouts/DocsLayout.astro";
import AppWindow from "../../components/AppWindow.astro";
---

<DocsLayout title="Replay Test — MCP Studio" current="replay-test">
  <p
    class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ E2E Testing ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">Replay Test</h1>
  <p
    class="text-base text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-10"
  >
    Open the Tests panel, pick a saved test, and run it. MCP Studio replays
    every recorded step against the live server and checks each result against
    the saved baseline. You can step through one action at a time or let the
    full suite run automatically.
  </p>

  <!-- Tests panel -->
  <section class="mb-10">
    <h2
      id="tests-panel"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Tests panel
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      The Tests panel lists all saved tests. Click any test to expand it and see
      its recorded steps, then choose how to run it.
    </p>
    <AppWindow caption="Tests panel — saved tests with their recorded steps.">
      <img
        src="/screenshots/mcp-studio-show-test.png"
        alt="Tests panel in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Step by step -->
  <section class="mb-10">
    <h2
      id="step-by-step"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Step-by-step
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Use the step controls to advance one action at a time. Each step shows its
      live result inline next to the recorded baseline so you can pinpoint
      exactly where something differs before continuing.
    </p>
    <AppWindow caption="Stepping through a recorded test one action at a time.">
      <img
        src="/screenshots/mcp-studio-run-step-by-step-test.gif"
        alt="Step-by-step test replay in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Full replay -->
  <section class="mb-10">
    <h2
      id="full-replay"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Full replay
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Click <strong class="text-[var(--foreground)]">Run</strong> to replay the entire
      test automatically. Every step is executed in sequence and checked against its
      saved assertions. A pass/fail report is shown at the end.
    </p>
    <AppWindow caption="Full E2E replay with pass/fail results." class="mb-4">
      <img
        src="/screenshots/mcp-studio-replay-test.gif"
        alt="Full test replay in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
    <AppWindow caption="Replay result — each step with its assertion outcome.">
      <img
        src="/screenshots/mcp-studio-replay-result.png"
        alt="Replay result in MCP Studio"
        class="w-full block"
        data-lightbox
      />
    </AppWindow>
  </section>

  <!-- Run history -->
  <section class="mb-10">
    <h2
      id="run-history"
      class="text-sm font-semibold uppercase tracking-widest text-[var(--foreground)] mb-3"
    >
      Run history
    </h2>
    <p class="text-sm text-[var(--muted-foreground)] leading-relaxed mb-4">
      Every replay is saved to the run history. Open the history drawer to
      browse past runs, compare results across runs, and re-inspect any previous
      pass/fail report without re-running the test.
    </p>
    <div class="border border-[var(--border)] bg-[var(--card)] p-4">
      <p class="text-xs font-semibold text-[var(--foreground)] mb-2">
        Tip — run after every release
      </p>
      <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
        Switch to the target profile and run the full suite after each deploy.
        The history lets you compare the new run against the previous one to
        spot regressions instantly.
      </p>
    </div>
  </section>
</DocsLayout>

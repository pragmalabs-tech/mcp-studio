---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Assertions — MCP Studio" current="assertions">
  <p
    class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
  >
    [ Assertions ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">
    Assertion modes
  </h1>
  <p
    class="text-sm text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-12"
  >
    [Intro: each recorded step has assertion points. You pick a mode per point.
    Modes control how the live result is compared to the baseline.]
  </p>

  <!-- Modes table -->
  <section class="mb-12">
    <div class="border border-[var(--border)]">
      <div
        class="flex gap-6 px-4 py-2 border-b border-[var(--border)] text-[10px] uppercase tracking-widest text-[var(--muted-foreground)]"
      >
        <span class="w-20 shrink-0">Mode</span>
        <span>What it checks</span>
      </div>
      {
        [
          {
            mode: "exact",
            desc: "Deep equality. The result must match the recorded value byte-for-byte.",
          },
          {
            mode: "shape",
            desc: "Same keys and types, values may differ. Good when content changes but structure should not.",
          },
          {
            mode: "flaky",
            desc: "Deep equality, but UUIDs, ISO dates, JWTs, and epoch timestamps are normalized before comparison. Array order is ignored for scalar arrays.",
          },
          {
            mode: "ignore",
            desc: "Always passes. Use to skip an assertion point that is not relevant to the test.",
          },
        ].map((row, i) => (
          <div
            class={`flex gap-6 px-4 py-4 text-xs ${i !== 0 ? "border-t border-[var(--border)]" : ""}`}
          >
            <span class="w-20 shrink-0 font-semibold text-[var(--foreground)]">
              {row.mode}
            </span>
            <span class="text-[var(--muted-foreground)] max-w-lg leading-relaxed">
              {row.desc}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Assertion points -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">
      Assertion points per action type
    </h2>
    <div class="border border-[var(--border)]">
      <div
        class="flex gap-6 px-4 py-2 border-b border-[var(--border)] text-[10px] uppercase tracking-widest text-[var(--muted-foreground)]"
      >
        <span class="w-40 shrink-0">Action</span>
        <span>Points you can assert on</span>
      </div>
      {
        [
          { action: "Tool call", points: ["input", "output", "status"] },
          { action: "Resource read", points: ["contents", "status"] },
          {
            action: "Widget click",
            points: ["rendered_html", "rendered_text"],
          },
          {
            action: "Widget text input",
            points: ["rendered_html", "rendered_text"],
          },
        ].map((row, i) => (
          <div
            class={`flex gap-6 px-4 py-3 text-xs ${i !== 0 ? "border-t border-[var(--border)]" : ""}`}
          >
            <span class="w-40 shrink-0 text-[var(--foreground)]">
              {row.action}
            </span>
            <span class="text-[var(--muted-foreground)]">
              {row.points.join(", ")}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- How to configure -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-1">
      Configuring assertions
    </h2>
    <p
      class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4 max-w-lg"
    >
      [Where in the UI to change a mode: open the replay result, expand a step,
      find the assertion point row, pick a mode from the dropdown. Changes apply
      live without re-running the test.]
    </p>
    <div
      class="border border-dashed border-[var(--border)] h-40 flex items-center justify-center text-xs text-[var(--muted-foreground)]"
    >
      screenshot: assertion point row with mode selector
    </div>
  </section>
</DocsLayout>

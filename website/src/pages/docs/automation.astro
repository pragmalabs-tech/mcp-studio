---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Automation — MCP Studio" current="automation">

  <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4">
    [ Automation E2E Testing ]
  </p>
  <h1 class="text-2xl font-bold text-[var(--foreground)] mb-4">Automation E2E Testing</h1>
  <p class="text-sm text-[var(--muted-foreground)] max-w-lg leading-relaxed mb-12">
    [Intro: interact with your MCP server normally, hit record, and MCP Studio saves the session as a replayable test.]
  </p>

  <!-- Record -->
  <section id="record" class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-1">Recording a session</h2>
    <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4 max-w-lg">
      [Step-by-step: click Record in the top bar, perform your actions (tool calls, resource reads, widget interactions), click Stop, name the test and add tags, save.]
    </p>

    <ol class="flex flex-col gap-3 mb-6">
      {[
        "Click Record in the top bar.",
        "Perform the actions you want to test: call tools, read resources, interact with widgets.",
        "Click Stop.",
        "Name the test, add a description and tags, save.",
      ].map((step, i) => (
        <li class="flex gap-3 text-xs text-[var(--muted-foreground)]">
          <span class="shrink-0 w-5 h-5 border border-[var(--border)] flex items-center justify-center text-[10px] text-[var(--foreground)]">
            {i + 1}
          </span>
          {step}
        </li>
      ))}
    </ol>

    <div class="border border-dashed border-[var(--border)] h-40 flex items-center justify-center text-xs text-[var(--muted-foreground)]">
      screenshot: record + save modal
    </div>
  </section>

  <!-- Replay -->
  <section id="replay" class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-1">Replay and run</h2>
    <p class="text-xs text-[var(--muted-foreground)] leading-relaxed mb-4 max-w-lg">
      [Describe the Tests drawer: open it, pick a test, run it. Mention step-by-step mode vs. auto-play. Explain what happens when a step fails (diff view).]
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px border border-[var(--border)] mb-6">
      {[
        { label: "Step mode", desc: "Advance one step at a time. Inspect results before continuing." },
        { label: "Auto-play", desc: "Run the full test automatically. Results shown at the end." },
      ].map((item) => (
        <div class="bg-[var(--card)] p-4">
          <p class="text-xs font-semibold text-[var(--foreground)] mb-1">{item.label}</p>
          <p class="text-xs text-[var(--muted-foreground)]">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="border border-dashed border-[var(--border)] h-40 flex items-center justify-center text-xs text-[var(--muted-foreground)]">
      screenshot: replay result dialog
    </div>
  </section>

  <!-- What gets recorded -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-[var(--foreground)] mb-3">What gets recorded</h2>
    <div class="border border-[var(--border)]">
      {[
        { action: "Tool call", points: "input, output, status" },
        { action: "Resource read", points: "URI, contents, status" },
        { action: "Widget click", points: "element selector, rendered HTML/text" },
        { action: "Widget text input", points: "element selector, value, rendered HTML/text" },
      ].map((row, i) => (
        <div class={`flex gap-6 px-4 py-3 text-xs ${i !== 0 ? "border-t border-[var(--border)]" : ""}`}>
          <span class="w-36 shrink-0 text-[var(--foreground)]">{row.action}</span>
          <span class="text-[var(--muted-foreground)]">{row.points}</span>
        </div>
      ))}
    </div>
  </section>

</DocsLayout>

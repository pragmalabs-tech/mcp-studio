---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const VIDEO_ID = "vCbNQKFpN78";
---

<Base>
  <Nav />

  <main class="overflow-hidden">
    <section
      class="pt-16 flex flex-col xl:flex-row xl:items-start px-8 xl:pl-8 xl:pr-0 gap-12 xl:gap-16"
    >
      <!-- Hero content -->
      <div class="w-full xl:flex-shrink-0 xl:w-[440px] py-8 pb-8 xl:pb-20">
        <p
          class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-6"
        >
          [ MCP Studio ]
        </p>
        <h1
          class="text-4xl sm:text-5xl font-bold leading-tight text-[var(--foreground)] mb-6"
        >
          The E2E Test Studio for <span
            class="text-emerald-500 dark:text-emerald-400">MCP Apps</span
          >.
        </h1>
        <p
          class="text-base text-[var(--muted-foreground)] leading-relaxed mb-10"
        >
          Call tools, inject mock data, and preview widgets live in your
          browser. Turn any interactive session into an automated end-to-end
          test in minutes.
        </p>

        <div class="flex flex-col gap-3">
          {
            [
              {
                label: "install",
                code: "curl -fsSL https://studio.pragmalabs.tech/install.sh | sh",
              },
              { label: "run", code: "mcp-studio" },
            ].map((t) => (
              <div class="border border-[var(--border)] bg-[var(--card)] overflow-hidden">
                <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
                  <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                  <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                  <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                  <span class="ml-2 text-xs text-[var(--muted-foreground)]">
                    {t.label}
                  </span>
                  <button
                    class="copy-btn ml-auto text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
                    data-copy={t.code}
                    title="Copy"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <rect x="9" y="9" width="13" height="13" rx="2" />
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                      </>
                    </svg>
                  </button>
                </div>
                <pre class="px-4 py-4 text-xs text-[var(--foreground)] leading-relaxed overflow-hidden"><code><span class="text-emerald-400">$</span> {t.code}</code></pre>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Screenshot with hover play button -->
      <div
        class="flex-1 min-w-0 group relative cursor-pointer"
        id="demo-trigger"
      >
        <!-- Window chrome -->
        <div
          class="border border-[var(--border)] bg-[var(--card)] overflow-hidden"
        >
          <div
            class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]"
          >
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
            <span class="ml-2 text-xs text-[var(--muted-foreground)]"
              >mcp studio</span
            >
          </div>
          <div class="relative">
            <img
              src="/screenshots/mcp-studio.png"
              alt="MCP Studio interface"
              class="w-full block"
            />
            <!-- Hover overlay -->
            <div
              class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center"
            >
              <div
                class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg"
              >
                <!-- Play icon -->
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="#111"
                  class="ml-1"
                >
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works: Cypress-style sticky left image + scrollable right steps -->
    <section class="py-24 px-8 max-w-screen-xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-20">
        <p
          class="text-xs font-semibold uppercase tracking-widest text-[var(--muted-foreground)] mb-4"
        >
          [ How it works ]
        </p>
        <h2
          class="text-3xl sm:text-4xl font-bold text-[var(--foreground)] leading-tight"
        >
          Record, test, and replay <span
            class="text-emerald-500 dark:text-emerald-400">MCP apps</span
          > like never before.
        </h2>
      </div>

      <!-- Steps: image left, timeline dot + text right -->
      <div class="relative flex flex-col gap-16">
        <!-- Vertical line running through all dots -->
        <div
          class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-px border-l border-dashed border-[var(--border)]"
        >
        </div>

        {
          [
            {
              title: "Hit Record Test",
              desc: "Click the Record Test button in the toolbar. Every tool call and widget interaction from this point is captured automatically — no code to write.",
              href: "/docs/manual-testing",
              img: "/screenshots/mcp-studio-record-test.png",
              label: null,
            },
            {
              title: "Call your MCP tools",
              desc: "Invoke any tool with custom arguments. Inject mock data without touching your code. Responses appear instantly in the log.",
              href: "/docs/manual-testing",
              img: "/screenshots/mcp-studio-execute-tool.gif",
              label: null,
            },
            {
              title: "Interact with the widget",
              desc: "See your widget render live in the browser. Switch between ChatGPT, Claude, desktop, and mobile viewports to test every context your users encounter.",
              href: "/docs/manual-testing",
              img: "/screenshots/mcp-studio-interactive-with-widget.gif",
              label: null,
            },
            {
              title: "Stop and save",
              desc: "Click Stop Record Test. The session is saved as a named, reproducible E2E test in seconds.",
              href: "/docs/automation",
              img: "/screenshots/mcp-studio-stop-record-test.png",
              label: null,
            },
            {
              title: "Replay on every change",
              desc: "Run the full test suite after any release or code change. Four assertion modes — exact, shape, flaky, ignore — give you precise control over what counts as a failure.",
              href: "/docs/assertions",
              img: "/screenshots/mcp-studio-replay-test.gif",
              label: null,
            },
          ].map((step, i) => {
            const isEven = i % 2 === 0;
            const imageBlock = (
              <div>
                {step.img ? (
                  <div class="border border-[var(--border)] overflow-hidden">
                    <div class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)]">
                      <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                      <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                      <span class="w-2 h-2 rounded-full bg-[var(--border)]" />
                      <span class="ml-2 text-xs text-[var(--muted-foreground)]">
                        mcp studio
                      </span>
                    </div>
                    <img src={step.img} alt={step.title} class="w-full block" />
                  </div>
                ) : (
                  <div class="border border-dashed border-[var(--border)] aspect-video flex flex-col items-center justify-center gap-3 text-center px-6">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="28"
                      height="28"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="opacity-30"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="2" />
                      <circle cx="8.5" cy="8.5" r="1.5" />
                      <polyline points="21 15 16 10 5 21" />
                    </svg>
                    <span class="text-xs text-[var(--muted-foreground)] leading-relaxed">
                      {step.label}
                    </span>
                  </div>
                )}
              </div>
            );
            const textBlock = (
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-emerald-500 dark:text-emerald-400 mb-3">
                  {String(i + 1).padStart(2, "0")}
                </p>
                <h3 class="text-lg font-bold text-[var(--foreground)] mb-3">
                  {step.title}
                </h3>
                <p class="text-sm text-[var(--muted-foreground)] leading-relaxed">
                  {step.desc}
                </p>
              </div>
            );
            return (
              <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto_1fr] gap-6 lg:gap-12 items-center">
                {/* Text always first in DOM → always on top on mobile */}
                <div class={isEven ? "lg:order-3" : "lg:order-1"}>{textBlock}</div>
                <div class={`hidden lg:flex flex-col items-center justify-center gap-1 z-10 lg:order-2`}>
                  <div class="w-9 h-9 rounded-full border border-[var(--border)] bg-[var(--background)] flex items-center justify-center text-[10px] font-bold text-emerald-500 dark:text-emerald-400">
                    {String(i + 1).padStart(2, "0")}
                  </div>
                </div>
                {/* Image always last in DOM → always below text on mobile */}
                <div class={isEven ? "lg:order-1" : "lg:order-3"}>{imageBlock}</div>
              </div>
            );
          })
        }
      </div>
    </section>
  </main>

  <!-- Demo modal (wired up when VIDEO_ID is set) -->
  <div
    id="demo-modal"
    class="hidden fixed inset-0 z-50 bg-black/90 items-center justify-center p-4"
  >
    <button
      id="demo-modal-close"
      class="absolute top-4 right-5 text-white text-3xl leading-none opacity-60 hover:opacity-100"
      >&times;</button
    >
    <div class="w-full max-w-[90vw] aspect-video">
      {
        VIDEO_ID ? (
          <iframe
            id="demo-iframe"
            src={`https://www.youtube.com/embed/${VIDEO_ID}?autoplay=1&vq=hd2160`}
            class="w-full h-full"
            allow="autoplay; encrypted-media"
            allowfullscreen
          />
        ) : (
          <div class="w-full h-full border border-[var(--border)] flex items-center justify-center text-[var(--muted-foreground)] text-sm">
            Video coming soon
          </div>
        )
      }
    </div>
  </div>

  <Footer />
</Base>

<script>
  // Copy buttons
  function initCopy() {
    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy!;
        await navigator.clipboard.writeText(text);
        const original = btn.innerHTML;
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        btn.style.color = "rgb(16 185 129)";
        setTimeout(() => {
          btn.innerHTML = original;
          btn.style.color = "";
        }, 1500);
      });
    });
  }
  initCopy();
  document.addEventListener("astro:page-load", initCopy);

  const trigger = document.getElementById("demo-trigger")!;
  const modal = document.getElementById("demo-modal")!;
  const closeBtn = document.getElementById("demo-modal-close")!;

  trigger.addEventListener("click", () => {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
  });

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  }

  closeBtn.addEventListener("click", closeModal);
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

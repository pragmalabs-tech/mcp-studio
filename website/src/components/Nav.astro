---

<header
  class="h-12 shrink-0 border-b border-[var(--border)] flex items-center px-4 sticky top-0 z-50 bg-[var(--background)]"
>
  <a href="/" class="flex items-center gap-2">
    <img src="/pragmalabs.png" alt="Pragma Labs" class="w-6 h-6" />
    <span class="font-semibold text-base text-[var(--foreground)]"
      >mcp studio</span
    >
  </a>

  <nav class="flex-1 flex items-center justify-end gap-1">
    <a
      href="/docs"
      class="inline-flex items-center h-8 px-2.5 text-sm text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
    >
      Docs
    </a>
    <a
      href="/roadmap"
      class="inline-flex items-center h-8 px-2.5 text-sm text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
    >
      Roadmap
    </a>
    <a
      href="/contact"
      class="inline-flex items-center h-8 px-2.5 text-sm text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors"
    >
      Contact
    </a>
  </nav>
</header>

---
export interface Props {
  label?: string;
  caption?: string;
  class?: string;
}

const { label = "mcp studio", caption, class: className = "" } = Astro.props;
---

<figure class={`w-full ${className}`}>
  <div
    class="border border-[var(--border)] bg-[var(--card)] overflow-hidden w-full"
  >
    <div
      class="flex items-center gap-1.5 px-3 py-2 border-b border-[var(--border)] shrink-0"
    >
      <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
      <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
      <span class="w-2 h-2 rounded-full bg-[var(--border)]"></span>
      <span class="ml-2 text-xs text-[var(--muted-foreground)]">{label}</span>
    </div>
    <div class="w-full">
      <slot />
    </div>
  </div>
  {
    caption && (
      <figcaption class="mt-2 text-xs text-[var(--muted-foreground)] leading-relaxed">
        {caption}
      </figcaption>
    )
  }
</figure>
